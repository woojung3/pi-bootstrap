# Copy or adapt into your project/global .envrc.
# Requires direnv: https://direnv.net/

# The real secret should be defined outside git, e.g. in ~/.config/secrets.env,
# your shell profile, 1Password/op, pass, etc.
# export LITELLM_MASTER_KEY="sk-..."

export LITELLM_API_KEY="$LITELLM_MASTER_KEY"
export OPENAI_API_KEY="$OPENAI_API_KEY"
